# Copy to .env.local (gitignored) and fill in your real key:
#   cp .env.local.example .env.local
#
# Never commit .env.local or paste API keys into source files.

QWEN_API_KEY=sk-your-dashscope-api-key-here
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_TEXT_MODEL=qwen3.7-plus

# Optional overrides
# QWEN_WEB_SEARCH_MODEL=qwen3.7-plus
# QWEN_VISION_MODEL=qwen-vl-plus

# Optional — third-party web search (DashScope web search is used by default when Qwen is configured)
# TAVILY_API_KEY=tvly-your-key-here
# BRAVE_SEARCH_API_KEY=your-brave-key-here
