# Copy to .env.local (gitignored) and fill in your real key:
#   cp .env.local.example .env.local
#
# Never commit .env.local or paste API keys into source files.

OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_REASONING_MODEL=gpt-5.6-sol
OPENAI_UTILITY_MODEL=gpt-5.6-luna

# Cost control for automatic background memory enrichment (minimum 30 seconds).
# Explicit user captures bypass this cooldown.
OPENAI_MEMORY_ENRICHMENT_COOLDOWN_SECONDS=300
